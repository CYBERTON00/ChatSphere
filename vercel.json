{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/node",
      "config": { "installCommand": "npm install" }
    },
    {
      "src": "client/**/*.tsx",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "https://chatsphere-server.up.railway.app/api/$1" },
    { "src": "/socket.io/(.*)", "dest": "https://chatsphere-server.up.railway.app/socket.io/$1" },
    { "src": "/(.*)", "dest": "/client/$1" }
  ]
}
